{
  "name": "cousin-jacks-cafe",
  "version": "1.0.0",
  "private": true,
  "description": "A polished Next.js website starter for Cousin Jack's Cafe in Guildford, NSW.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run build",
    "security:audit": "npm audit --audit-level=low",
    "security:prod": "npm audit --omit=dev --audit-level=low"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=8.19.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "packageManager": "npm@10.9.2"
}
